# UniCore Production Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED - Security Secrets (generate strong random values!)
# =============================================================================

# Django secret key - use a strong random string, at least 50 characters
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# JWT secret key - use a different strong random string
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
JWT_SECRET_KEY=

# =============================================================================
# REQUIRED - Database Configuration
# =============================================================================

POSTGRES_DB=unicore_db
POSTGRES_USER=unicore_user
POSTGRES_PASSWORD=  # Strong password, at least 16 characters
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSL_MODE=require

# =============================================================================
# REQUIRED - Redis Configuration
# =============================================================================

REDIS_URL=redis://:your_redis_password@localhost:6379/0
REDIS_PASSWORD=  # Strong password for Redis

# =============================================================================
# REQUIRED - Application Configuration
# =============================================================================

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# =============================================================================
# OPTIONAL - Site URLs
# =============================================================================

NEXT_PUBLIC_API_URL=https://api.your-domain.com
NEXT_PUBLIC_SITE_URL=https://www.your-domain.com

# =============================================================================
# OPTIONAL - Email Configuration (SMTP)
# =============================================================================

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=  # App password for email
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@your-domain.com

# =============================================================================
# OPTIONAL - SMS (Africastalking)
# =============================================================================

AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox