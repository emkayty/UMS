{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "UMS - University Management System on AWS",
  "Parameters": {
    "Environment": {
      "Type": "String",
      "Default": "prod",
      "AllowedValues": ["dev", "staging", "prod"]
    },
    "InstanceType": {
      "Type": "String",
      "Default": "t3.small",
      "AllowedValues": ["t3.small", "t3.medium", "t3.large"]
    },
    "KeyName": {
      "Type": "AWS::EC2::KeyPair::KeyName",
      "Description": "SSH key pair name"
    },
    "DBInstanceClass": {
      "Type": "String",
      "Default": "db.t3.small",
      "AllowedValues": ["db.t3.small", "db.t3.medium"]
    },
    "MultiAZDatabase": {
      "Type": "String",
      "Default": "false",
      "AllowedValues": ["true", "false"]
    }
  },
  "Mappings": {
    "RegionAMI": {
      "us-east-1": {"AMI": "ami-0c55b159cbfafe1f0"},
      "us-west-2": {"AMI": "ami-0892d3c7ee96c0bf7"},
      "eu-west-1": {"AMI": "ami-0d71ea30463ec3bb1c"}
    }
  },
  "Resources": {
    "VPC": {
      "Type": "AWS::EC2::VPC",
      "Properties": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsHostnames": true,
        "EnableDnsSupport": true,
        "Tags": [{"Key": "Name", "Value": {"Fn::Join": ["-", [{"Ref": "Environment"}, "ums-vpc"]]}}]
      }
    },
    "PublicSubnet": {
      "Type": "AWS::EC2::Subnet",
      "Properties": {
        "CidrBlock": "10.0.1.0/24",
        "VpcId": {"Ref": "VPC"},
        "MapPublicIpOnInstance": true,
        "Tags": [{"Key": "Name", "Value": {"Fn::Join": ["-", [{"Ref": "Environment"}, "ums-subnet"]]}}]
      }
    },
    "InternetGateway": {
      "Type": "AWS::EC2::InternetGateway",
      "Properties": {
        "Tags": [{"Key": "Name", "Value": {"Fn::Join": ["-", [{"Ref": "Environment"}, "ums-igw"]]}}]
      }
    },
    "GatewayAttachment": {
      "Type": "AWS::EC2::VPCGatewayAttachment",
      "Properties": {
        "VpcId": {"Ref": "VPC"},
        "InternetGatewayId": {"Ref": "InternetGateway"}
      }
    },
    "PublicRouteTable": {
      "Type": "AWS::EC2::RouteTable",
      "Properties": {
        "VpcId": {"Ref": "VPC"},
        "Tags": [{"Key": "Name", "Value": {"Fn::Join": ["-", [{"Ref": "Environment"}, "ums-public-rt"]]}}]
      }
    },
    "PublicRoute": {
      "Type": "AWS::EC2::Route",
      "DependsOn": "GatewayAttachment",
      "Properties": {
        "RouteTableId": {"Ref": "PublicRouteTable"},
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": {"Ref": "InternetGateway"}
      }
    },
    "SubnetRouteTableAssociation": {
      "Type": "AWS::EC2::SubnetRouteTableAssociation",
      "Properties": {
        "SubnetId": {"Ref": "PublicSubnet"},
        "RouteTableId": {"Ref": "PublicRouteTable"}
      }
    },
    "SecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupDescription": "UMS Security Group",
        "SecurityGroupIngress": [
          {"IpProtocol": "tcp", "FromPort": 80, "ToPort": 80, "CidrIp": "0.0.0.0/0"},
          {"IpProtocol": "tcp", "FromPort": 443, "ToPort": 443, "CidrIp": "0.0.0.0/0"},
          {"IpProtocol": "tcp", "FromPort": 22, "ToPort": 22, "CidrIp": "0.0.0.0/0"}
        ],
        "Tags": [{"Key": "Name", "Value": {"Fn::Join": ["-", [{"Ref": "Environment"}, "ums-sg"]]}}],
        "VpcId": {"Ref": "VPC"}
      }
    },
    "Database": {
      "Type": "AWS::RDS::DBInstance",
      "Properties": {
        "DBInstanceIdentifier": {"Fn::Join": ["-", [{"Ref": "Environment"}, "ums-db"]]},
        "DBInstanceClass": {"Ref": "DBInstanceClass"},
        "Engine": "postgres",
        "EngineVersion": "14.7",
        "MasterUsername": "ums_user",
        "MasterUserPassword": "change_me_in_production",
        "AllocatedStorage": 20,
        "StorageType": "gp2",
        "VPCSecurityGroups": [
          {"Fn::GetAtt": "DatabaseSecurityGroup.GroupId"}
        ],
        "Tags": [{"Key": "Name", "Value": {"Fn::Join": ["-", [{"Ref": "Environment"}, "ums-db"]]}}]
      },
      "DeletionPolicy": "Snapshot"
    },
    "DBSecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupDescription": "RDS Security Group",
        "SecurityGroupIngress": [
          {"IpProtocol": "tcp", "FromPort": 5432, "ToPort": 5432, "SourceSecurityGroupId": {"Ref": "SecurityGroup"}}
        ],
        "Tags": [{"Key": "Name", "Value": {"Fn::Join": ["-", [{"Ref": "Environment"}, "ums-db-sg"]]}}],
        "VpcId": {"Ref": "VPC"}
      }
    },
    "DatabaseSecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupDescription": "Database access from app",
        "Tags": [{"Key": "Name", "Value": {"Fn::Join": ["-", [{"Ref": "Environment"}, "ums-app-db-sg"]]}}],
        "VpcId": {"Ref": "VPC"}
      }
    },
    "EC2Instance": {
      "Type": "AWS::EC2::Instance",
      "Properties": {
        "InstanceType": {"Ref": "InstanceType"},
        "KeyName": {"Ref": "KeyName"},
        "ImageId": {"Fn::FindInMap": ["RegionAMI", {"Ref": "AWS::Region"}, "AMI"]},
        "NetworkInterfaces": [
          {
            "AssociatePublicIpAddress": true,
            "DeviceIndex": "0",
            "GroupSet": [{"Ref": "SecurityGroup"}],
            "SubnetId": {"Ref": "PublicSubnet"}
          }
        ],
        "Tags": [{"Key": "Name", "Value": {"Fn::Join": ["-", [{"Ref": "Environment"}, "ums-server"]]}}],
        "UserData": {"Fn::Base64": {"Fn::Join": ["\n", [
          "#!/bin/bash",
          "yum update -y",
          "yum install -y python310 git",
          "cd /opt",
          "git clone https://github.com/emkayty/UMS.git",
          "cd UMS",
          "python3 -m venv venv",
          "source venv/bin/activate",
          "pip install -r backend/requirements.txt",
          "chmod +x backend/unicore/wsgi.py",
          "echo 'DATABASE_URL=postgres://ums_user:change_me@", {"Fn::GetAtt": ["Database", "Endpoint.Address"], ":5432/ums' > .env",
          "python manage.py migrate",
          "python manage.py collectstatic --noinput"
        ]]}}
      }
    },
    "LoadBalancer": {
      "Type": "AWS::ElasticLoadBalancingV2::LoadBalancer",
      "Properties": {
        "Scheme": "internet-facing",
        "SecurityGroups": [{"Ref": "SecurityGroup"}],
        "Subnets": [{"Ref": "PublicSubnet"}],
        "Tags": [{"Key": "Name", "Value": {"Fn::Join": ["-", [{"Ref": "Environment"}, "ums-alb"]]}}]
      }
    },
    "ALBTargetGroup": {
      "Type": "AWS::ElasticLoadBalancingV2::TargetGroup",
      "Properties": {
        "Port": 80,
        "Protocol": "HTTP",
        "TargetType": "instance",
        "Targets": [{"Id": {"Ref": "EC2Instance"}}],
        "Vpc": {"Ref": "VPC"}
      }
    },
    "ALBListener": {
      "Type": "AWS::ElasticLoadBalancingV2::Listener",
      "Properties": {
        "DefaultActions": [{"TargetGroupArn": {"Ref": "ALBTargetGroup"}, "Type": "forward"}],
        "LoadBalancerArn": {"Ref": "LoadBalancer"},
        "Port": 80,
        "Protocol": "HTTP"
      }
    }
  },
  "Outputs": {
    "WebsiteURL": {
      "Description": "Application URL",
      "Value": {"Fn::GetAtt": ["LoadBalancer", "DNSName"]},
      "Export": {"Name": {"Fn::Join": ["-", [{"Ref": "Environment"], "-ums-url"]]}
    },
    "InstanceID": {
      "Description": "EC2 Instance ID",
      "Value": {"Ref": "EC2Instance"},
      "Export": {"Name": {"Fn::Join": ["-", [{"Ref": "Environment"], "-ums-instance"]]}
    },
    "DatabaseEndpoint": {
      "Description": "Database Endpoint",
      "Value": {"Fn::GetAtt": ["Database", "Endpoint.Address"]},
      "Export": {"Name": {"Fn::Join": ["-", [{"Ref": "Environment"], "-ums-db-endpoint"]]}
    }
  }
}