# UMS Environment Configuration
# Production-ready environment settings

# Debug settings
DEBUG=false
SECRET_KEY=your-production-secret-key-change-this
ALLOWED_HOSTS=ums.edu,api.ums.edu,localhost,127.0.0.1

# Database
DATABASE_URL=postgres://user:password@localhost:5432/ums_db

# Redis (for caching/sessions)
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=https://ums.edu,https://www.ums.edu

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# Email (configure for production)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_STORAGE_BUCKET_NAME=ums-media
AWS_S3_REGION_NAME=us-east-1

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/ums/app.log

# Security
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_BROWSER_XSS_FILTER=true
SECURE_CONTENT_TYPE_NOSNIFF=true